# Clerk Authentication
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk Redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Database
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Resend (Contact Form Email)
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The email address that receives contact form submissions
CONTACT_EMAIL=your-email@example.com
# The sender address for outgoing emails. Must be a Resend-verified domain.
# Must use a Resend-verified domain. Before you verify zawly.app, use: "Zawly Calendar <onboarding@resend.dev>"
CONTACT_FROM_EMAIL="Zawly Calendar <noreply@zawly.app>"